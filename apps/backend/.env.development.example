# ============================================================
# 개발 환경 변수 (.env.development 파일로 복사하여 사용)
# cp .env.development.example .env.development
#
# 용도: Neon dev 브랜치에 연결할 때 (클라우드 개발 DB)
# .env (로컬 Docker)보다 우선순위가 높아 이 파일이 있으면 Neon dev를 사용
#
# 주의: .env.development는 gitignore 처리됨 (실제 값이 들어가므로)
# ============================================================

NODE_ENV=development

# Neon dev 브랜치 연결 문자열
# Neon Console → 프로젝트 → Branches → dev 브랜치 선택 → Connection string 복사
DATABASE_URL=postgresql://<user>:<password>@<dev-branch-endpoint>.neon.tech/neondb?sslmode=require&channel_binding=require

# NEON_BRANCH 반드시 설정 - 안전 가드가 main/dev를 구분하는 데 사용
NEON_BRANCH=dev

# 개발용 값 (프로덕션과 다른 값 사용 권장)
JWT_SECRET=dev-jwt-secret-change-me-in-production!!
RECEIVER_API_KEY=dev-receiver-key

FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=debug
