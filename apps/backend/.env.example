PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require
JWT_SECRET=<최소_32자_랜덤_문자열_생성: openssl rand -base64 48>
RECEIVER_API_KEY=<안전한_랜덤_키_생성: openssl rand -hex 24>
# 1 또는 true: HMI는 DB에 등록된 ICCID만 허용(installationId 폴백 비활성)
# RECEIVER_REQUIRE_ICCID=1
FRONTEND_ORIGIN=https://<your-app>.vercel.app
LOG_LEVEL=info
