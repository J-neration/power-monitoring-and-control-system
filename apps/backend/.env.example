# ============================================================
# 로컬 기본 환경 변수 템플릿 (.env 파일로 복사하여 사용)
# cp .env.example .env
#
# 용도: 로컬 Docker Postgres 사용 (인터넷 불필요, 가장 안전한 로컬 개발)
# Neon dev 브랜치를 사용하려면 .env.development.example을 참고하세요.
# ============================================================

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# 로컬 Docker Postgres (docker-compose.yml 실행 후 사용 가능)
# 시작: docker compose up -d postgres
DATABASE_URL=postgresql://pmcs:pmcs@localhost:5432/pmcs

# Neon 브랜치 명시 (로컬 Docker 사용 시 생략 가능)
# Neon dev 브랜치 사용 시: NEON_BRANCH=dev
# NEON_BRANCH=

# 개발용 JWT 시크릿 (프로덕션에서는 Railway에서 별도 설정)
JWT_SECRET=dev-jwt-secret-change-me-in-production!!

# HMI 수신 API 키 (개발용)
RECEIVER_API_KEY=dev-receiver-key

# 로컬 프론트엔드 주소
FRONTEND_ORIGIN=http://localhost:3000

LOG_LEVEL=debug
