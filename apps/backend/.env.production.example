# ============================================================
# PRODUCTION 환경 변수 - Railway 대시보드에서 직접 설정
# 이 파일은 템플릿 전용입니다. 실제 값을 여기에 넣지 마세요.
# ============================================================

NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# Neon PostgreSQL - main 브랜치 (https://console.neon.tech)
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require

# Neon 브랜치 명시 (안전 가드용 - 반드시 main으로 설정)
NEON_BRANCH=main

# 최소 32자 랜덤 문자열
# 생성: openssl rand -base64 48
JWT_SECRET=<최소_32자_이상_랜덤_문자열>

# HMI 디바이스 수신 API 키
# 생성: openssl rand -hex 24
RECEIVER_API_KEY=<랜덤_HEX_키>

# Vercel 배포 URL (예: https://pmcs-yourname.vercel.app)
FRONTEND_ORIGIN=https://<your-app>.vercel.app

LOG_LEVEL=info

# ============================================================
# Railway 설정 방법
# 1. Railway 프로젝트 → Variables 탭
# 2. 위 변수들을 하나씩 추가
# 3. 절대로 이 파일에 실제 값을 입력하지 말 것
# ============================================================
