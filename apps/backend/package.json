{
  "name": "@pmcs/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/src/index.js",
    "lint": "echo \"No linter configured\"",
    "test": "node --test --import tsx \"src/**/*.test.ts\"",

    "db:migrate:dev": "cross-env NODE_ENV=development prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "cross-env NODE_ENV=development tsx prisma/seed.ts",
    "db:reset": "cross-env NODE_ENV=development prisma migrate reset",
    "db:studio": "cross-env NODE_ENV=development prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/websocket": "8.2.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "7.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.4",
    "fastify": "4.26.2",
    "pg": "^8.18.0",
    "pino": "8.17.2",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "18.19.39",
    "pino-pretty": "10.2.3",
    "prisma": "7.3.0",
    "tsx": "latest",
    "typescript": "latest"
  }
}
