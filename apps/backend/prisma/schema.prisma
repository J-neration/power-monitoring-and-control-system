generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id         String   @id @default(cuid())
  name       String
  location   String
  status     String   @default("offline")
  lastSeenAt DateTime @default(now())
  lastValue  Float    @default(0)
  lastIp     String   @default("unknown")
  vL1        Float    @default(0)
  vL2        Float    @default(0)
  vL3        Float    @default(0)
  iL1        Float    @default(0)
  iL2        Float    @default(0)
  iL3        Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
