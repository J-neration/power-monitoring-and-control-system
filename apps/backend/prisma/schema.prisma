generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id         String   @id @default(cuid())
  name       String
  location   String
  status     String   @default("offline")
  lastSeenAt DateTime @default(now())
  lastValue  Float    @default(0)
  lastIp     String   @default("unknown")
  gridCurrentL1    Float @default(0)
  gridCurrentL2    Float @default(0)
  gridCurrentL3    Float @default(0)
  loadCurrentL1    Float @default(0)
  loadCurrentL2    Float @default(0)
  loadCurrentL3    Float @default(0)
  tpf1             Float @default(0)
  tpf2             Float @default(0)
  dpf1             Float @default(0)
  dpf2             Float @default(0)
  gridCurrentTHDL1 Float @default(0)
  gridCurrentTHDL2 Float @default(0)
  gridCurrentTHDL3 Float @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
