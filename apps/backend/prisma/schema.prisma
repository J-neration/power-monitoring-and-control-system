generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

/* =========================
 * 1) Site (현장 – 아파트 단지 등)
 * ========================= */
model Site {
  id            String          @id              // e.g. "lotte-songdo-xi"
  name          String                           // e.g. "송도 크리스탈자이"
  client        String  @default("unknown")       // e.g. "lotte" (건설사)
  region        String                           // e.g. "인천"
  address       String

  installations Installation[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/* =========================
 * 2) Installation (설치지점)
 * ========================= */
model Installation {
  id        String   @id                         // device_id (PSVG-RNDTESTx)
  siteId    String
  label     String                               // 변전실 / 102동 / 전기실

  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  device           Device?                     // 최신 텔레메트리 (1:1)
  telemetryRecords TelemetryRecord[]           // 시계열 이력

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
}

/* =========================
 * 3) Device (최신 텔레메트리)
 * ========================= */
model Device {
  installationId String   @id                    // = device_id, Installation.id와 동일
  status         String   @default("offline")

  model          String   @default("psvg")       // psta | paf | psvg
  capacity       Int      @default(200)           // HMI 정격용량 (kVAR): 200 | 150

  moduleStatus   Int[]    @default([])
  numOfMods      Int      @default(0)

  lastSeenAt     DateTime @default(now())
  lastValue      Float?
  lastIp         String?  @default("unknown")

  // 전압 (V)
  vL1             Float?
  vL2             Float?
  vL3             Float?

  // 전류 (A)
  gridCurrentL1    Float?
  gridCurrentL2    Float?
  gridCurrentL3    Float?
  loadCurrentL1    Float?
  loadCurrentL2    Float?
  loadCurrentL3    Float?

  // 전류 THD (%)
  loadCurrentTHDL1 Float?
  loadCurrentTHDL2 Float?
  loadCurrentTHDL3 Float?
  gridCurrentTHDL1 Float?
  gridCurrentTHDL2 Float?
  gridCurrentTHDL3 Float?

  // 피상전력 (kVA)
  uncompS          Float?
  compS            Float?

  // 유효전력 (kW)
  uncompP          Float?
  compP            Float?

  // 무효전력 (kvar)
  uncompQ          Float?
  compQ            Float?
  uncompH          Float?
  compH            Float?

  // 역률 (%)
  tpf1             Float?
  tpf2             Float?
  dpf1             Float?
  dpf2             Float?

  // 온도 (°C)
  areaTemp              Float[]  @default([])   // 구역 온도 (max 4)
  moduleTemp            Float[]  @default([])   // 모듈 온도 (max 6)

  // 팬 속도 (RPM)
  fanSpeed              Float[]  @default([])   // 팬 속도 (max 2)

  // 용량 (kVAR)
  totalCapacity         Float?   // HMI 연결 총 모듈 합 용량
  operatingCapacity     Float?   // 운전 중인 모듈 용량
  reactivePowerCapacity Float?   // 무효전력 발생 용량
  availableMargin       Float?   // 여유 마진 (= totalCapacity - operatingCapacity)

  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/* =========================
 * 4) TelemetryRecord (시계열 이력)
 * ========================= */
model TelemetryRecord {
  id             String       @id @default(cuid())
  installationId String
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  recordedAt     DateTime     @default(now())  // 수신 시각 (나중에 HMI timestamp로 교체 가능)

  moduleStatus     Int[]   @default([])
  numOfMods        Int?

  // 전압 (V)
  vL1              Float?
  vL2              Float?
  vL3              Float?

  // 전류 (A)
  gridCurrentL1    Float?
  gridCurrentL2    Float?
  gridCurrentL3    Float?
  loadCurrentL1    Float?
  loadCurrentL2    Float?
  loadCurrentL3    Float?

  // 전류 THD (%)
  loadCurrentTHDL1 Float?
  loadCurrentTHDL2 Float?
  loadCurrentTHDL3 Float?
  gridCurrentTHDL1 Float?
  gridCurrentTHDL2 Float?
  gridCurrentTHDL3 Float?

  // 피상전력 (kVA)
  uncompS          Float?
  compS            Float?

  // 유효전력 (kW)
  uncompP          Float?
  compP            Float?

  // 무효전력 (kvar)
  uncompQ          Float?
  compQ            Float?
  uncompH          Float?
  compH            Float?

  // 역률 (%)
  tpf1             Float?
  tpf2             Float?
  dpf1             Float?
  dpf2             Float?

  // 온도 (°C)
  areaTemp              Float[]  @default([])
  moduleTemp            Float[]  @default([])

  // 팬 속도 (RPM)
  fanSpeed              Float[]  @default([])

  // 용량 (kVAR)
  totalCapacity         Float?
  operatingCapacity     Float?
  reactivePowerCapacity Float?
  availableMargin       Float?

  @@index([installationId, recordedAt])
}
