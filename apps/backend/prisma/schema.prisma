generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id         String   @id @default(cuid())
  name       String
  location   String
  status     String   @default("offline")
  moduleStatus Int[]  @default([])
  lastSeenAt DateTime @default(now())
  lastValue  Float    @default(0)
  lastIp     String   @default("unknown")
  vL1             Float @default(0)
  vL2             Float @default(0)
  vL3             Float @default(0)
  gridCurrentL1    Float @default(0)
  gridCurrentL2    Float @default(0)
  gridCurrentL3    Float @default(0)
  loadCurrentL1    Float @default(0)
  loadCurrentL2    Float @default(0)
  loadCurrentL3    Float @default(0)
  loadCurrentTHDL1 Float @default(0)
  loadCurrentTHDL2 Float @default(0)
  loadCurrentTHDL3 Float @default(0)
  uncompS          Float @default(0)
  uncompP          Float @default(0)
  uncompQ          Float @default(0)
  uncompH          Float @default(0)
  compS            Float @default(0)
  compP            Float @default(0)
  compQ            Float @default(0)
  compH            Float @default(0)
  tpf1             Float @default(0)
  tpf2             Float @default(0)
  dpf1             Float @default(0)
  dpf2             Float @default(0)
  gridCurrentTHDL1 Float @default(0)
  gridCurrentTHDL2 Float @default(0)
  gridCurrentTHDL3 Float @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
