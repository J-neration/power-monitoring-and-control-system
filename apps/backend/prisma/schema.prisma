generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

/* =========================
 * 1) Site (현장 – 아파트 단지 등)
 * ========================= */
model Site {
  id            String          @id              // e.g. "lotte-songdo-xi"
  name          String                           // e.g. "송도 크리스탈자이"
  client        String  @default("unknown")       // e.g. "lotte" (건설사)
  region        String                           // e.g. "인천"
  address       String

  installations Installation[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/* =========================
 * 2) Installation (설치지점)
 * ========================= */
model Installation {
  id        String   @id                         // device_id (PSVG-RNDTESTx)
  siteId    String
  label     String                               // 변전실 / 102동 / 전기실
  capacity  Float?                               // 설치지점 용량 (필요 없으면 빼도 됨)

  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  device Device?                               // 최신 텔레메트리 (1:1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
}

/* =========================
 * 3) Device (최신 텔레메트리)
 * ========================= */
model Device {
  installationId String   @id                    // = device_id, Installation.id와 동일
  status         String   @default("offline")

  moduleStatus   Int[]    @default([])
  numOfMods      Int      @default(0)

  lastSeenAt     DateTime @default(now())
  lastValue      Float?
  lastIp         String?  @default("unknown")

  vL1             Float?
  vL2             Float?
  vL3             Float?
  gridCurrentL1    Float?
  gridCurrentL2    Float?
  gridCurrentL3    Float?
  loadCurrentL1    Float?
  loadCurrentL2    Float?
  loadCurrentL3    Float?
  loadCurrentTHDL1 Float?
  loadCurrentTHDL2 Float?
  loadCurrentTHDL3 Float?

  uncompS          Float?
  uncompP          Float?
  uncompQ          Float?
  uncompH          Float?
  compS            Float?
  compP            Float?
  compQ            Float?
  compH            Float?

  tpf1             Float?
  tpf2             Float?
  dpf1             Float?
  dpf2             Float?

  gridCurrentTHDL1 Float?
  gridCurrentTHDL2 Float?
  gridCurrentTHDL3 Float?

  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
