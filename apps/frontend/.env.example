# 로컬 백엔드 주소 (백엔드 dev 서버 실행 후 사용 가능)
NEXT_PUBLIC_API_BASE=http://localhost:4000
# 커맨드 전송용 백엔드 주소 (미설정 시 NEXT_PUBLIC_API_BASE 사용)
COMMAND_API_BASE=https://pmcsbackend-production.up.railway.app
