# ============================================================
# PRODUCTION 환경 변수 - Vercel 대시보드에서 직접 설정
# Settings → Environment Variables → Production
# 이 파일은 템플릿 전용입니다. 실제 값을 여기에 넣지 마세요.
# ============================================================

# Railway 백엔드 URL (예: https://pmcsbackend-production.up.railway.app)
NEXT_PUBLIC_API_BASE=https://<your-backend>.up.railway.app

# 커맨드 전송용 백엔드 URL (일반적으로 NEXT_PUBLIC_API_BASE와 동일)
COMMAND_API_BASE=https://<your-backend>.up.railway.app

# ============================================================
# Vercel 설정 방법
# 1. Vercel 프로젝트 → Settings → Environment Variables
# 2. Environment: Production 선택 후 위 변수 추가
# 3. 절대로 이 파일에 실제 값을 입력하지 말 것
# ============================================================
