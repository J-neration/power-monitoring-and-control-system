{
  "name": "power-monitoring-and-control-system",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"frontend,backend\" --prefix-colors \"cyan,green\" --prefix \"[{name}]\" \"yarn workspace @pmcs/frontend dev\" \"yarn workspace @pmcs/backend dev\"",
    "dev:frontend": "yarn workspace @pmcs/frontend dev",
    "dev:backend": "yarn workspace @pmcs/backend dev",
    "build": "yarn workspace @pmcs/frontend build && yarn workspace @pmcs/backend build",
    "lint": "yarn workspace @pmcs/frontend lint && yarn workspace @pmcs/backend lint"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.27.3",
    "concurrently": "^9.2.1"
  }
}
